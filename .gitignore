# ==========================================
# Reports (generated artifacts)
# ==========================================
reports/

# If you ever generate reports elsewhere, keep them out too
**/report/
**/reports/

# Keep an empty top-level reports/ folder in repo
!reports/
!reports/.gitkeep

# Office / PDF exports (common generated artifacts)
*.doc
*.docx
*.ppt
*.pptx
*.xls
*.xlsx
*.pdf
*.rtf
*.odt
*.ods
*.odp

# Common generated media artifacts
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.svg

# Allow docs & skill assets to be versioned
!docs/**/*.doc
!docs/**/*.docx
!docs/**/*.ppt
!docs/**/*.pptx
!docs/**/*.xls
!docs/**/*.xlsx
!docs/**/*.pdf
!docs/**/*.rtf
!docs/**/*.odt
!docs/**/*.ods
!docs/**/*.odp
!docs/**/*.png
!docs/**/*.jpg
!docs/**/*.jpeg
!docs/**/*.gif
!docs/**/*.webp
!docs/**/*.svg

!skills/**/assets/**/*.doc
!skills/**/assets/**/*.docx
!skills/**/assets/**/*.ppt
!skills/**/assets/**/*.pptx
!skills/**/assets/**/*.xls
!skills/**/assets/**/*.xlsx
